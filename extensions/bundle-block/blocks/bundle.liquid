{% assign app_url = "https://brandsbro-upsell.onrender.com" %}

<div id="bundle-widget-{{ block.id }}" style="display:none; border:2px solid #000; border-radius:12px; padding:20px; margin:20px 0; background:#fafafa;">
  <div style="margin-bottom:16px;">
    <span style="background:#000; color:#fff; font-size:11px; font-weight:600; padding:3px 10px; border-radius:20px; text-transform:uppercase; letter-spacing:0.08em;">Bundle Deal</span>
    <h3 style="font-size:18px; font-weight:700; margin:8px 0 4px;">{{ block.settings.title }}</h3>
    <p style="font-size:14px; color:#666; margin:0;">{{ block.settings.subtitle }}</p>
  </div>
  <div id="bundle-products-{{ block.id }}" style="display:flex; gap:12px; flex-wrap:wrap; margin-bottom:16px;"></div>
  <div style="display:flex; align-items:center; gap:16px;">
    <div id="bundle-savings-{{ block.id }}" style="font-size:15px; font-weight:600; color:#008060;"></div>
    <button id="bundle-btn-{{ block.id }}" type="button"
      style="flex:1; background:#000; color:#fff; border:none; border-radius:8px; padding:14px 20px; font-size:15px; font-weight:600; cursor:pointer;">
      {{ block.settings.button_text | default: 'Add Bundle to Cart' }}
    </button>
  </div>
</div>

<script>
(function() {
  var blockId = "{{ block.id }}";
  var shopDomain = "{{ shop.permanent_domain }}";
  var productId = "{{ product.id }}";
  var appUrl = "{{ app_url }}";

  fetch(appUrl + "/api/bundles?shop=" + shopDomain + "&productId=" + productId)
    .then(function(r) { return r.json(); })
    .then(function(data) {
      if (!data.bundle) return;
      var bundle = data.bundle;
      var widget = document.getElementById("bundle-widget-" + blockId);
      var productsEl = document.getElementById("bundle-products-" + blockId);
      var savingsEl = document.getElementById("bundle-savings-" + blockId);
      var btn = document.getElementById("bundle-btn-" + blockId);
      var products = bundle.products || [];

      productsEl.innerHTML = products.map(function(p, i) {
        return (i > 0 ? '<span style="font-size:20px;color:#999;align-self:center;">+</span>' : '') +
          '<div style="display:flex;align-items:center;gap:8px;background:#fff;border:1px solid #e5e5e5;border-radius:8px;padding:8px 12px;flex:1;min-width:140px;">' +
          (p.image ? '<img src="' + p.image + '" style="width:40px;height:40px;object-fit:cover;border-radius:4px;" />' : '') +
          '<div><p style="font-size:13px;font-weight:600;margin:0 0 2px;">' + p.title + '</p>' +
          '<p style="font-size:12px;color:#666;margin:0;">$' + p.price + '</p></div></div>';
      }).join('');

      var total = products.reduce(function(s, p) { return s + parseFloat(p.price || 0); }, 0);
      var disc = bundle.discountValue || 0;
      var dtype = bundle.discountType || "PERCENTAGE";
      var savings = dtype === "PERCENTAGE" ? (total * disc / 100) : disc;
      savingsEl.textContent = "Save $" + savings.toFixed(2) + " (" + disc + (dtype === "PERCENTAGE" ? "%" : "$") + " off)";
      widget.style.display = "block";

      btn.addEventListener("click", function() {
        btn.disabled = true;
        btn.textContent = "Adding...";

        var items = products.map(function(p) {
          return { id: p.variantId.split("/").pop(), quantity: 1 };
        });

        // Get all section IDs on the page that contain cart
        var sectionIds = [];
        document.querySelectorAll("[id]").forEach(function(el) {
          if (el.id && (
            el.id.includes("cart") ||
            el.id.includes("Cart") ||
            el.tagName.toLowerCase() === "cart-drawer" ||
            el.tagName.toLowerCase() === "cart-notification"
          )) {
            var sectionEl = el.closest("[data-section-id]");
            if (sectionEl) sectionIds.push(sectionEl.dataset.sectionId);
          }
        });

        // Always include these common section IDs
        sectionIds = sectionIds.concat(["cart-drawer", "cart-icon-bubble", "cart-notification-product", "cart-notification-button"]);
        sectionIds = [...new Set(sectionIds)];

        fetch("/cart/add.js", {
          method: "POST",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify({
            items: items,
            sections: sectionIds.join(","),
            sections_url: window.location.pathname
          })
        })
        .then(function(r) { return r.json(); })
        .then(function(response) {
          btn.textContent = "✓ Added!";
          btn.style.background = "#008060";

          // Update all returned sections in DOM
          if (response.sections) {
            var parser = new DOMParser();
            Object.keys(response.sections).forEach(function(sectionId) {
              var html = response.sections[sectionId];
              var doc = parser.parseFromString(html, "text/html");

              // Find matching element on page and replace
              var sourceEl = doc.querySelector("[data-section-id='" + sectionId + "']") || doc.body.firstElementChild;
              var targetEl = document.querySelector("[data-section-id='" + sectionId + "']") ||
                             document.querySelector("cart-drawer") ||
                             document.querySelector("#cart-notification");

              if (sourceEl && targetEl) {
                targetEl.innerHTML = sourceEl.innerHTML;
                // Open if it has an open method
                if (typeof targetEl.open === "function") targetEl.open();
                targetEl.removeAttribute("inert");
                targetEl.setAttribute("open", "");
              }
            });
          }

          setTimeout(function() {
            btn.textContent = "{{ block.settings.button_text | default: 'Add Bundle to Cart' }}";
            btn.style.background = "#000";
            btn.disabled = false;
          }, 3000);
        })
        .catch(function(err) {
          console.error("Cart error:", err);
          btn.textContent = "Error — try again";
          btn.style.background = "#000";
          btn.disabled = false;
        });
      });
    });
})();
</script>

{% schema %}
{
  "name": "Product Bundle",
  "target": "section",
  "settings": [
    { "type": "text", "id": "title", "label": "Bundle title", "default": "Frequently Bought Together" },
    { "type": "text", "id": "subtitle", "label": "Subtitle", "default": "Save when you buy these together" },
    { "type": "text", "id": "button_text", "label": "Button text", "default": "Add Bundle to Cart" }
  ]
}
{% endschema %}
