{% comment %}
  Product Bundle App Block
  Shows bundle offer on product pages
{% endcomment %}

{% assign bundle_api = shop.metafields.bundle_app.api_url %}

<div id="bundle-block-{{ block.id }}" class="bundle-block" style="display:none">
  <div class="bundle-block__inner">
    <div class="bundle-block__header">
      <span class="bundle-block__tag">Bundle Deal</span>
      <h3 class="bundle-block__title">{{ block.settings.title }}</h3>
      <p class="bundle-block__subtitle">{{ block.settings.subtitle }}</p>
    </div>

    <div class="bundle-block__products" id="bundle-products-{{ block.id }}">
      <!-- Populated by JS -->
    </div>

    <div class="bundle-block__footer">
      <div class="bundle-block__savings" id="bundle-savings-{{ block.id }}"></div>
      <button
        class="bundle-block__btn"
        id="bundle-btn-{{ block.id }}"
        type="button"
      >
        {{ block.settings.button_text | default: 'Add Bundle to Cart' }}
      </button>
    </div>
  </div>
</div>

<style>
  .bundle-block {
    border: 2px solid #000;
    border-radius: 12px;
    padding: 20px;
    margin: 20px 0;
    background: #fafafa;
  }
  .bundle-block__header { margin-bottom: 16px; }
  .bundle-block__tag {
    display: inline-block;
    background: #000;
    color: #fff;
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.08em;
    padding: 3px 10px;
    border-radius: 20px;
    margin-bottom: 8px;
    text-transform: uppercase;
  }
  .bundle-block__title {
    font-size: 18px;
    font-weight: 700;
    margin: 0 0 4px;
  }
  .bundle-block__subtitle {
    font-size: 14px;
    color: #666;
    margin: 0;
  }
  .bundle-block__products {
    display: flex;
    gap: 12px;
    flex-wrap: wrap;
    margin-bottom: 16px;
  }
  .bundle-product-item {
    display: flex;
    align-items: center;
    gap: 8px;
    background: #fff;
    border: 1px solid #e5e5e5;
    border-radius: 8px;
    padding: 8px 12px;
    flex: 1;
    min-width: 140px;
  }
  .bundle-product-item img {
    width: 40px;
    height: 40px;
    object-fit: cover;
    border-radius: 4px;
  }
  .bundle-product-item__info { flex: 1; }
  .bundle-product-item__title {
    font-size: 13px;
    font-weight: 600;
    margin: 0 0 2px;
    line-height: 1.3;
  }
  .bundle-product-item__price {
    font-size: 12px;
    color: #666;
    margin: 0;
  }
  .bundle-plus {
    font-size: 20px;
    font-weight: 300;
    color: #999;
    align-self: center;
  }
  .bundle-block__footer {
    display: flex;
    align-items: center;
    gap: 16px;
  }
  .bundle-block__savings {
    font-size: 15px;
    font-weight: 600;
    color: #008060;
  }
  .bundle-block__btn {
    flex: 1;
    background: #000;
    color: #fff;
    border: none;
    border-radius: 8px;
    padding: 14px 20px;
    font-size: 15px;
    font-weight: 600;
    cursor: pointer;
    transition: background 0.2s;
  }
  .bundle-block__btn:hover { background: #333; }
  .bundle-block__btn:disabled { background: #999; cursor: not-allowed; }
</style>

<script>
(function() {
  const blockId = "{{ block.id }}";
  const shopDomain = "{{ shop.permanent_domain }}";
  const currentProductId = "{{ product.id }}";
  const appUrl = "{{ app.url }}";

  async function loadBundle() {
    try {
      const res = await fetch(
        `${appUrl}/api/bundles?shop=${shopDomain}&productId=${currentProductId}`
      );
      const data = await res.json();

      if (!data.bundle) return;

      const bundle = data.bundle;
      const block = document.getElementById(`bundle-block-${blockId}`);
      if (!block) return;

      // Render products
      const productsContainer = document.getElementById(`bundle-products-${blockId}`);
      const products = bundle.products ?? [];

      productsContainer.innerHTML = products.map((p, i) => `
        ${i > 0 ? '<span class="bundle-plus">+</span>' : ''}
        <div class="bundle-product-item">
          ${p.image ? `<img src="${p.image}" alt="${p.title}" />` : ''}
          <div class="bundle-product-item__info">
            <p class="bundle-product-item__title">${p.title}</p>
            <p class="bundle-product-item__price">$${p.price}</p>
          </div>
        </div>
      `).join('');

      // Calculate savings
      const totalOriginal = products.reduce((sum, p) => sum + parseFloat(p.price || 0), 0);
      const discount = bundle.discountValue ?? 0;
      const discountType = bundle.discountType ?? "PERCENTAGE";
      const savings = discountType === "PERCENTAGE"
        ? (totalOriginal * discount / 100)
        : discount;
      const savingsEl = document.getElementById(`bundle-savings-${blockId}`);
      savingsEl.textContent = `Save $${savings.toFixed(2)} (${discount}${discountType === "PERCENTAGE" ? "%" : "$"} off)`;

      // Show block
      block.style.display = "block";

      // Add to cart handler
      document.getElementById(`bundle-btn-${blockId}`).addEventListener("click", async function() {
        this.disabled = true;
        this.textContent = "Adding...";

        const items = products.map((p) => ({
          id: p.variantId.replace("gid://shopify/ProductVariant/", ""),
          quantity: 1,
        }));

        try {
          await fetch("/cart/add.js", {
            method: "POST",
            headers: { "Content-Type": "application/json" },
            body: JSON.stringify({ items }),
          });
          this.textContent = "Added to cart!";
          setTimeout(() => {
            window.location.href = "/cart";
          }, 800);
        } catch (err) {
          this.textContent = "Error — try again";
          this.disabled = false;
        }
      });

    } catch (err) {
      console.error("Bundle block error:", err);
    }
  }

  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", loadBundle);
  } else {
    loadBundle();
  }
})();
</script>

{% schema %}
{
  "name": "Product Bundle",
  "target": "section",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Bundle title",
      "default": "Frequently Bought Together"
    },
    {
      "type": "text",
      "id": "subtitle",
      "label": "Subtitle",
      "default": "Save when you buy these together"
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Button text",
      "default": "Add Bundle to Cart"
    }
  ]
}
{% endschema %}
